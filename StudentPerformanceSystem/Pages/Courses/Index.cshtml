@page
@model StudentPerformanceSystem.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Courses";
}

<div class="courses-page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Courses</h1>
        <a class="btn btn-primary" asp-page="/Pages/Courses/Create">Create Course</a>
    </div>

    <div class="card">
        <div class="card-body">
            <p class="lead">List of courses (placeholder).</p>
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Teacher</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Mathematics</td>
                        <td>Dr. Ivanov</td>
                        <td><a class="btn btn-sm btn-outline-secondary" href="#">Details</a></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
