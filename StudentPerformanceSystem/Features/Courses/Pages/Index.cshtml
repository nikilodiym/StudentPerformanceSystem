@page
@model StudentPerformanceSystem.Features.Courses.IndexModel
@{
    ViewData["Title"] = "Courses";
}

<div class="courses-page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Courses</h1>
        <a class="btn btn-primary" asp-page="/Features/Courses/Pages/Create">Create Course</a>
    </div>

    <div class="card">
        <div class="card-body">
            <p class="lead">Here will be a list of courses. This is a placeholder page styled with Bootstrap and site.css.</p>
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Code</th>
                        <th>Teacher</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Mathematics</td>
                        <td>MATH101</td>
                        <td>Dr. Ivanov</td>
                        <td><a class="btn btn-sm btn-outline-secondary" href="#">Details</a></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
